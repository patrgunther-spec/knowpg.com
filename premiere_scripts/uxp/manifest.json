{
  "id": "com.knowpg.clipimporter",
  "name": "Clip Importer",
  "version": "1.0.0",
  "main": "index.js",
  "host": {
    "app": "premierepro",
    "minVersion": "25.0.0"
  },
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "panel",
      "id": "clipImporterPanel",
